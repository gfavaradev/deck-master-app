rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: true if the requester has role 'administrator' in their user document.
    // Safe against missing documents: get() on a non-existent doc returns empty data,
    // so .get('role', 'user') falls back to 'user'.
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', 'user') == 'administrator';
    }

    // Yu-Gi-Oh catalog
    match /yugioh_catalog/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Pokémon catalog
    match /pokemon_catalog/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // One Piece catalog
    match /onepiece_catalog/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // CardTrader shared price cache
    match /cardtrader_prices/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // App config (changelog, feature flags)
    match /app_config/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // User profiles
    match /users/{userId} {
      // Owner reads own doc; admins can read all docs (for admin panel user list)
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());

      // New users can create their own doc, but only with role 'user' (not self-promote)
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.get('role', 'user') == 'user';

      // Owner can update own profile but cannot change role; admins can update anything
      allow update: if request.auth != null && (
        isAdmin() ||
        (request.auth.uid == userId &&
         request.resource.data.get('role', 'user') == resource.data.get('role', 'user'))
      );

      allow delete: if isAdmin();
    }

    // User sub-collections (collections, albums, cards, decks) — owner only
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
